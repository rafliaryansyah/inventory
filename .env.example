# ── Database — Neon PostgreSQL ───────────────────────────────
# App is deployed on Railway and connects to a Neon Postgres instance.
# Single pooled connection string (Neon's pooler supports Prisma).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Auth — NextAuth.js v5 (Auth.js) ──────────────────────────
# Generate with: npx auth secret
AUTH_SECRET="replace-with-generated-secret"
# Set to your Railway public URL in production (e.g. https://assetflow.up.railway.app)
AUTH_URL="http://localhost:3000"

# ── File storage — Cloudflare R2 (S3-compatible) ─────────────
# Used for foto aset, uploaded resources, & generated Delivery Note PDFs.
# Leave blank to disable uploads (the app degrades gracefully).
# Setup: buat bucket + API token (Object Read & Write) di dashboard R2,
# isi 3 kredensial di bawah.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="assetflow"
# Base URL PUBLIK bucket — WAJIB di-set agar preview foto muncul di browser
# (bucket R2 privat secara default, jadi tanpa ini URL tidak bisa diakses).
# Aktifkan dulu di dashboard: R2 → bucket → Settings → Public Development URL
# (dapat https://pub-<hash>.r2.dev) ATAU hubungkan Custom Domain (disarankan utk prod).
# Aturan: harus diawali https://, TANPA trailing slash, TANPA nama bucket di path,
# dan JANGAN pakai S3 endpoint (…r2.cloudflarestorage.com) — itu butuh auth (403).
#   contoh benar: https://pub-abc123.r2.dev  atau  https://assets.handal.co.id
R2_PUBLIC_URL=""
